<Window x:Class="SMFTrace.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMFTrace.Wpf"
        xmlns:controls="clr-namespace:SMFTrace.Wpf.Controls"
        xmlns:converters="clr-namespace:SMFTrace.Wpf.Converters"
        xmlns:views="clr-namespace:SMFTrace.Wpf.Views"
        xmlns:vm="clr-namespace:SMFTrace.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="700" Width="1200"
        Background="{DynamicResource WindowBackgroundBrush}"
        Icon="Resources/app-icon.ico"
        AllowDrop="True"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:RightInsetConverter x:Key="RightInsetConverter"/>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E23"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="ControlHoverBackgroundBrush" Color="#505050"/>
        <SolidColorBrush x:Key="ControlPressedBackgroundBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="ControlDisabledBackgroundBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#555555"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#666666"/>
        <SolidColorBrush x:Key="SurfaceBackgroundBrush" Color="#121212"/>
        <SolidColorBrush x:Key="SurfacePanelBrush" Color="#1B1B20"/>
        <SolidColorBrush x:Key="SurfaceBorderBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TabItemBackgroundBrush" Color="#111111"/>
        <SolidColorBrush x:Key="TabItemHoverBrush" Color="#161616"/>
        <SolidColorBrush x:Key="TabItemSelectedBrush" Color="#000000"/>
        <SolidColorBrush x:Key="TabItemSelectedBorderBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="TempoBadgeBrush" Color="#C83C3C41"/>
        <SolidColorBrush x:Key="PlaylistRowBrush" Color="#252526"/>
        <SolidColorBrush x:Key="PlaylistAltRowBrush" Color="#1F1F23"/>
        <SolidColorBrush x:Key="PlaylistHeaderBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="PlaylistSelectionBrush" Color="#2E3A52"/>
        <SolidColorBrush x:Key="PlaylistNowPlayingGlyphBrush" Color="#5DA9FF"/>
        <Style TargetType="Button" x:Key="ToolbarButtonStyle">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource ControlDisabledBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="28"/>
        </Style>

        <Style TargetType="Button" x:Key="MiniZoomButtonStyle" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="MinWidth" Value="20"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="Slider" x:Key="TempoAdjustmentSliderStyle">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="20">
                            <Track x:Name="PART_Track" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{x:Null}"
                                                  IsHitTestVisible="False"
                                                  Background="#3A3A40"
                                                  Height="4"
                                                  VerticalAlignment="Center">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{x:Null}"
                                                  IsHitTestVisible="False"
                                                  Background="#3A3A40"
                                                  Height="4"
                                                  VerticalAlignment="Center">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid Width="16" Height="16">
                                                    <Ellipse Stroke="#1D4FA6" StrokeThickness="1">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush Center="0.35,0.35" GradientOrigin="0.35,0.35" RadiusX="0.9" RadiusY="0.9">
                                                                <GradientStop Color="#D6E6FF" Offset="0"/>
                                                                <GradientStop Color="#4C92FF" Offset="0.55"/>
                                                                <GradientStop Color="#1D5FE0" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Ellipse Width="4" Height="4" Fill="#F6FBFF" Opacity="0.9" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="3"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton" x:Key="IconToggleButtonStyle">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="MinWidth" Value="32"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="{DynamicResource ControlDisabledBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton" x:Key="TrackToggleButtonStyle" BasedOn="{StaticResource IconToggleButtonStyle}">
            <Setter Property="MinWidth" Value="26"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="DarkComboBoxStyle">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="InstrumentSelectorStyle" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          IsEnabled="{TemplateBinding IsEnabled}"
                                          FocusVisualStyle="{x:Null}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="3">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="6,2,4,2"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <Border Grid.Column="1"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,0,0,0">
                                        <Path HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 6 0 L 3 4 Z"
                                              Fill="{DynamicResource TextPrimaryBrush}"
                                              Stretch="Uniform"/>
                                    </Border>
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource ControlBackgroundBrush}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3">
                                    <ScrollViewer Margin="2"
                                                  CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="ToggleButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox" x:Key="DarkCheckBoxStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>

        <Style TargetType="ToolBar">
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolBar">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ToolBarPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" x:Key="{x:Static ToolBar.SeparatorStyleKey}">
            <Setter Property="Background" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="6,4"/>
        </Style>

        <Style TargetType="TabControl" x:Key="DarkTabControlStyle">
            <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem" x:Key="DarkTabItemStyle">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource TabItemBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TabItemSelectedBrush}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource TabItemSelectedBorderBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TabItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}" Margin="2">
            <ToolBar Background="{DynamicResource PanelBackgroundBrush}" Band="0" BandIndex="0">
                <Button Command="{Binding OpenCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Open">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE8E5;"/>
                </Button>
                <Button Command="{Binding AddFilesCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Add to playlist">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE710;"/>
                </Button>
                <Separator/>
                <Button Command="{Binding PlayCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Play">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE768;"/>
                </Button>
                <Button Command="{Binding PauseCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Pause">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE769;"/>
                </Button>
                <Button Command="{Binding StopCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Stop">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE71A;"/>
                </Button>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding ShowPlaylistNavigation, Converter={StaticResource BoolToVisibility}}">
                    <Button Command="{Binding PreviousCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Previous">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE892;"/>
                    </Button>
                    <Button Command="{Binding NextCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Next">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE893;"/>
                    </Button>
                </StackPanel>
                <ToggleButton IsChecked="{Binding LoopPlayback}"
                              Style="{StaticResource IconToggleButtonStyle}"
                              ToolTip="Loop playback">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE8EE;"/>
                </ToggleButton>
                <ToggleButton IsChecked="{Binding IsDarkTheme}"
                              Style="{StaticResource IconToggleButtonStyle}"
                              ToolTip="{Binding ThemeToggleToolTip}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="{Binding ThemeIconGlyph}"/>
                </ToggleButton>
                <Separator/>
                <Button Command="{Binding PanicCommand}" Style="{StaticResource IconButtonStyle}" ToolTip="Panic (All Notes Off)">
                    <TextBlock FontFamily="Segoe UI Symbol" FontSize="14" Text="⚠"/>
                </Button>
                <Separator/>
                <ComboBox ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="Name"
                          Width="200"
                          Margin="4,0"
                          ToolTip="MIDI output device"
                          Style="{StaticResource InstrumentSelectorStyle}"/>
                <ComboBox ItemsSource="{Binding DefaultInstruments}"
                          SelectedItem="{Binding SelectedDefaultInstrument}"
                          DisplayMemberPath="Name"
                          MinWidth="220"
                          Margin="6,0,4,0"
                          ToolTip="Default Instrument"
                          VerticalAlignment="Center"
                          Style="{StaticResource InstrumentSelectorStyle}"/>
                </ToolBar>
                 <ToolBar Background="{DynamicResource PanelBackgroundBrush}"
                     Band="0"
                     BandIndex="1"
                     DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <ToggleButton Content="Compact" IsChecked="{Binding CompactPitchRange}" Style="{StaticResource IconToggleButtonStyle}" ToolTip="Compact lane pitch range to used notes"/>
                <ToggleButton Content="Overlay" IsChecked="{Binding OverlayMode}" Style="{StaticResource IconToggleButtonStyle}" ToolTip="Overlay all tracks with distinct colors"/>
                <ToggleButton Content="Mute/Solo" IsChecked="{Binding ShowTrackControls}" Style="{StaticResource IconToggleButtonStyle}" ToolTip="Show track mute/solo"/>
                <ToggleButton Content="Grid" IsChecked="{Binding ShowBarsBeatsGrid}" Style="{StaticResource IconToggleButtonStyle}"/>
                <ToggleButton Content="No SysEx"
                              IsChecked="{Binding DisableSysExOutput}"
                              Style="{StaticResource IconToggleButtonStyle}"
                              ToolTip="Disable SysEx output"/>
                <ToggleButton Content="Notes" IsChecked="{Binding ShowNoteNames}" Style="{StaticResource IconToggleButtonStyle}" ToolTip="Show note names in lane headers"/>
                <ToggleButton Content="Keys" IsChecked="{Binding ShowPianoKeys}" Style="{StaticResource IconToggleButtonStyle}" ToolTip="Show piano keys in lane headers"/>
                <ToggleButton Content="Lyrics"
                              IsChecked="{Binding ShowLyricsLane}"
                              Style="{StaticResource IconToggleButtonStyle}"
                              ToolTip="Show lyrics lane"
                              Visibility="{Binding HasLyrics, Converter={StaticResource BoolToVisibility}}"/>
                <ToggleButton Content="Tempo" IsChecked="{Binding ShowTempo}" Style="{StaticResource IconToggleButtonStyle}"/>
                <Separator/>
                <TextBlock Text="Tempo" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="6,0,4,0"/>
                <Slider Minimum="{Binding MinTempoAdjustmentBpm}"
                    Maximum="{Binding MaxTempoAdjustmentBpm}"
                    Value="{Binding TempoAdjustmentBpm, Mode=TwoWay}"
                    Width="140"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True"
                    SmallChange="1"
                    LargeChange="5"
                    AutoToolTipPlacement="TopLeft"
                    AutoToolTipPrecision="0"
                    VerticalAlignment="Center"
                    Style="{StaticResource TempoAdjustmentSliderStyle}"
                    ToolTip="Tempo adjustment (+/- BPM)"
                    PreviewMouseLeftButtonDown="TempoAdjustmentSlider_PreviewMouseLeftButtonDown"/>
                <TextBlock Text="{Binding TempoAdjustmentLabel}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="6,0" MinWidth="70"/>
                <Separator/>
            </ToolBar>
        </ToolBarTray>

        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Margin="0,0,10,0"
                Panel.ZIndex="5">
            <Button Content="-"
                Command="{Binding ZoomOutCommand}"
                Style="{StaticResource MiniZoomButtonStyle}"
                ToolTip="Zoom out"/>
                <Button Content="+"
                    Command="{Binding ZoomInCommand}"
                    Style="{StaticResource MiniZoomButtonStyle}"
                    Margin="4,0,0,0"
                    ToolTip="Zoom in"/>
        </StackPanel>

        <!-- Main Content -->
        <TabControl x:Name="MainTabs"
                Grid.Row="1"
                Background="{DynamicResource SurfaceBackgroundBrush}"
                Style="{StaticResource DarkTabControlStyle}"
                ItemContainerStyle="{StaticResource DarkTabItemStyle}">
            <TabItem Header="Piano Roll">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="220"
                            Background="{DynamicResource SurfacePanelBrush}"
                            BorderBrush="{DynamicResource SurfaceBorderBrush}"
                            BorderThickness="0,0,1,0"
                            Visibility="{Binding ShowTrackControls, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Tracks"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontWeight="SemiBold"
                                       Margin="10,8,10,6"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding TrackPlaybackStates}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ToggleButton Grid.Column="1"
                                                              Content="Mute"
                                                              ToolTip="Mute"
                                                              IsChecked="{Binding IsMuted}"
                                                              Style="{StaticResource TrackToggleButtonStyle}"/>
                                                <ToggleButton Grid.Column="2"
                                                              Content="Solo"
                                                              ToolTip="Solo"
                                                              IsChecked="{Binding IsSolo}"
                                                              Style="{StaticResource TrackToggleButtonStyle}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Grid Grid.Column="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <controls:PianoRollPanel x:Name="PianoRoll"
                                                     CurrentTime="{Binding CurrentTime}"
                                                     TotalDuration="{Binding TotalDuration}"
                                                     WindowSeconds="{Binding WindowSeconds, Mode=TwoWay}"
                                                     PitchRowHeight="{Binding PitchRowHeight}"
                                                     MidiFormat="{Binding MidiFormat}"
                                                     ShowTempo="{Binding ShowTempo}"
                                                     RenderTempoBadge="False"
                                                     ShowBarsBeatsGrid="{Binding ShowBarsBeatsGrid}"
                                                     ShowNoteNames="{Binding ShowNoteNames}"
                                                     ShowPianoKeys="{Binding ShowPianoKeys}"
                                                     CompactPitchRange="{Binding CompactPitchRange}"
                                                     OverlayMode="{Binding OverlayMode}"
                                                     IsDarkTheme="{Binding IsDarkTheme}"
                                                     IsPlaying="{Binding IsPlaying}"
                                                     ShowLyricsLane="{Binding ShowLyricsLane}"
                                                     Lyrics="{Binding Lyrics}"
                                                     TrackPlaybackStates="{Binding TrackPlaybackStates}">
                                <controls:PianoRollPanel.TempoBadgeRightInset>
                                    <MultiBinding Converter="{StaticResource RightInsetConverter}" ConverterParameter="8">
                                        <Binding ElementName="ZoomButtons" Path="ActualWidth"/>
                                        <Binding ElementName="ZoomButtons" Path="Margin"/>
                                    </MultiBinding>
                                </controls:PianoRollPanel.TempoBadgeRightInset>
                            </controls:PianoRollPanel>
                        </ScrollViewer>
                        <StackPanel Orientation="Vertical"
                                    x:Name="ZoomButtons"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,4,24,0"
                                    Panel.ZIndex="5">
                            <Button Content="-"
                                    Command="{Binding VerticalZoomOutCommand}"
                                    Style="{StaticResource MiniZoomButtonStyle}"
                                    ToolTip="Decrease lane height"/>
                                <Button Content="+"
                                    Command="{Binding VerticalZoomInCommand}"
                                    Style="{StaticResource MiniZoomButtonStyle}"
                                    ToolTip="Increase lane height"
                                    Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Panel.ZIndex="6"
                                Background="{DynamicResource TempoBadgeBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                Visibility="{Binding ShowTempo, Converter={StaticResource BoolToVisibility}}">
                            <Border.Margin>
                                <MultiBinding Converter="{StaticResource RightInsetConverter}" ConverterParameter="8,10">
                                    <Binding ElementName="ZoomButtons" Path="ActualWidth"/>
                                    <Binding ElementName="ZoomButtons" Path="Margin"/>
                                </MultiBinding>
                            </Border.Margin>
                            <TextBlock Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontFamily="Segoe UI"
                                       FontSize="14"
                                       Text="{Binding EffectiveTempo, StringFormat={}{0:F1} BPM}"/>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Playlist">
                <DataGrid x:Name="PlaylistGrid"
                          ItemsSource="{Binding PlaylistEntries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="True"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                                                    Background="{DynamicResource WindowBackgroundBrush}"
                                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                                    RowBackground="{DynamicResource PlaylistRowBrush}"
                                                    AlternatingRowBackground="{DynamicResource PlaylistAltRowBrush}"
                          EnableRowVirtualization="True"
                          MouseDoubleClick="PlaylistGrid_MouseDoubleClick">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                                                        <Setter Property="Background" Value="{DynamicResource PlaylistHeaderBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource SurfaceBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PlaylistSelectionBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PlaylistSelectionBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PlaylistSelectionBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource PlaylistSelectionBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="24">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource PlaylistNowPlayingGlyphBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value=""/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsNowPlaying}" Value="True">
                                                        <Setter Property="Text" Value=">"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Title" Binding="{Binding DisplayTitle}" Width="2*"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding DurationDisplay}" Width="Auto"/>
                        <DataGridTextColumn Header="Tempo" Binding="{Binding TempoDisplay}" Width="Auto"/>
                        <DataGridTextColumn Header="Time Sig" Binding="{Binding TimeSignatureDisplay}" Width="Auto"/>
                        <DataGridTextColumn Header="Key" Binding="{Binding KeySignatureDisplay}" Width="Auto"/>
                        <DataGridTextColumn Header="SMF" Binding="{Binding SmfTypeDisplay}" Width="Auto"/>
                        <DataGridTextColumn Header="Tracks" Binding="{Binding TrackCount}" Width="Auto">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="SysEx" Binding="{Binding SysExPresentDisplay}" Width="Auto"/>
                        <DataGridTextColumn Header="Lyrics" Binding="{Binding LyricsPresentDisplay}" Width="Auto"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding FilePath}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Diagnostics">
                <views:DiagnosticsView x:Name="DiagnosticsView"
                                       DataContext="{Binding Diagnostics}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar with Seek -->
        <Grid Grid.Row="2" Background="{DynamicResource AccentBrush}" Height="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding CurrentTime, StringFormat='{}{0:mm\\:ss\\.fff}'}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       FontFamily="Consolas"/>

            <TextBlock Grid.Column="0"
                       Text="Loading..."
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="100,0,0,0"
                       FontFamily="Consolas"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <Slider x:Name="SeekSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    Value="{Binding SeekPosition, Mode=TwoWay}"
                    VerticalAlignment="Center"
                    Margin="8,0"
                    Thumb.DragStarted="SeekSlider_DragStarted"
                    Thumb.DragCompleted="SeekSlider_DragCompleted"/>

            <TextBlock Grid.Column="2"
                       Text="{Binding TotalDuration, StringFormat='{}{0:mm\\:ss\\.fff}'}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       FontFamily="Consolas"/>
        </Grid>
    </Grid>
</Window>
