<Window x:Class="SMFTrace.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMFTrace.Wpf"
        xmlns:controls="clr-namespace:SMFTrace.Wpf.Controls"
        xmlns:views="clr-namespace:SMFTrace.Wpf.Views"
        xmlns:vm="clr-namespace:SMFTrace.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="700" Width="1200"
        Background="#1E1E23"
        Icon="Resources/app-icon.ico"
        AllowDrop="True"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <Style TargetType="Button" x:Key="ToolbarButtonStyle">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" x:Key="DarkComboBoxStyle">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style TargetType="ComboBox" x:Key="DarkComboBoxWhiteArrowStyle" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#3C3C3C"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#3C3C3C"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
            </Style.Resources>
        </Style>

        <Style TargetType="ComboBox" x:Key="InstrumentSelectorStyle" BasedOn="{StaticResource DarkComboBoxWhiteArrowStyle}">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="6,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#404046"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          IsEnabled="{TemplateBinding IsEnabled}"
                                          FocusVisualStyle="{x:Null}"
                                          Focusable="False"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="22"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="6,2,4,2"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <Border Grid.Column="1"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1,0,0,0">
                                        <Path HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 6 0 L 3 4 Z"
                                              Fill="White"
                                              Stretch="Uniform"/>
                                    </Border>
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#2D2D30"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer Margin="2"
                                                  CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger SourceName="ToggleButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleButton" Property="Background" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}"/>
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{Binding BorderBrush, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox" x:Key="DarkCheckBoxStyle">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>

        <Style TargetType="ToolBar">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolBar">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ToolBarPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" x:Key="{x:Static ToolBar.SeparatorStyleKey}">
            <Setter Property="Background" Value="#555"/>
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="6,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBarTray Grid.Row="0" Background="#2D2D30">
            <ToolBar Background="#2D2D30" Band="0" BandIndex="0">
                <Button Content="Open" Command="{Binding OpenCommand}" Style="{StaticResource ToolbarButtonStyle}"/>
                <Separator/>
                <Button Content="Play" Command="{Binding PlayCommand}" Style="{StaticResource ToolbarButtonStyle}"/>
                <Button Content="Pause" Command="{Binding PauseCommand}" Style="{StaticResource ToolbarButtonStyle}"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Style="{StaticResource ToolbarButtonStyle}"/>
                <CheckBox Content="Loop" IsChecked="{Binding LoopPlayback}" Style="{StaticResource DarkCheckBoxStyle}" ToolTip="Loop playback at end"/>
                <Separator/>
                <ComboBox ItemsSource="{Binding Devices}"
                          SelectedItem="{Binding SelectedDevice}"
                          DisplayMemberPath="Name"
                          Width="200"
                          Margin="4,0"
                          ToolTip="MIDI output device"
                          Style="{StaticResource InstrumentSelectorStyle}"/>
                <ComboBox ItemsSource="{Binding DefaultInstruments}"
                          SelectedItem="{Binding SelectedDefaultInstrument}"
                          DisplayMemberPath="Name"
                          MinWidth="220"
                          Margin="6,0,4,0"
                          ToolTip="Default Instrument"
                          VerticalAlignment="Center"
                          Style="{StaticResource InstrumentSelectorStyle}"/>
            </ToolBar>
            <ToolBar Background="#2D2D30" Band="0" BandIndex="1">
                <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ToolBar}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox Content="Tempo" IsChecked="{Binding ShowTempo}" Style="{StaticResource DarkCheckBoxStyle}"/>
                        <CheckBox Content="Grid" IsChecked="{Binding ShowBarsBeatsGrid}" Style="{StaticResource DarkCheckBoxStyle}"/>
                        <CheckBox Content="Notes" IsChecked="{Binding ShowNoteNames}" Style="{StaticResource DarkCheckBoxStyle}" ToolTip="Show note names in lane headers"/>
                        <CheckBox Content="Keys" IsChecked="{Binding ShowPianoKeys}" Style="{StaticResource DarkCheckBoxStyle}" ToolTip="Show piano keys in lane headers"/>
                        <CheckBox Content="Compact" IsChecked="{Binding CompactPitchRange}" Style="{StaticResource DarkCheckBoxStyle}" ToolTip="Compact lane pitch range to used notes"/>
                        <CheckBox Content="Overlay" IsChecked="{Binding OverlayMode}" Style="{StaticResource DarkCheckBoxStyle}" ToolTip="Overlay all tracks with distinct colors"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Separator/>
                        <TextBlock Text="Zoom:" VerticalAlignment="Center" Foreground="White" Margin="4,0"/>
                        <Button Content="+" Command="{Binding ZoomInCommand}" Width="30" Style="{StaticResource ToolbarButtonStyle}" MinWidth="30"/>
                        <Button Content="-" Command="{Binding ZoomOutCommand}" Width="30" Style="{StaticResource ToolbarButtonStyle}" MinWidth="30"/>
                    </StackPanel>
                </Grid>
            </ToolBar>
        </ToolBarTray>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Background="#252526">
            <TabItem Header="Piano Roll">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <controls:PianoRollPanel x:Name="PianoRoll"
                                             CurrentTime="{Binding CurrentTime}"
                                             TotalDuration="{Binding TotalDuration}"
                                             WindowSeconds="{Binding WindowSeconds, Mode=TwoWay}"
                                             ShowTempo="{Binding ShowTempo}"
                                             ShowBarsBeatsGrid="{Binding ShowBarsBeatsGrid}"
                                             ShowNoteNames="{Binding ShowNoteNames}"
                                             ShowPianoKeys="{Binding ShowPianoKeys}"
                                             CompactPitchRange="{Binding CompactPitchRange}"
                                             OverlayMode="{Binding OverlayMode}"
                                             IsPlaying="{Binding IsPlaying}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Diagnostics">
                <views:DiagnosticsView x:Name="DiagnosticsView"
                                       DataContext="{Binding Diagnostics}"/>
            </TabItem>
        </TabControl>

        <!-- Status Bar with Seek -->
        <Grid Grid.Row="2" Background="#007ACC" Height="28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding CurrentTime, StringFormat='{}{0:mm\\:ss\\.fff}'}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       FontFamily="Consolas"/>

            <Slider x:Name="SeekSlider"
                    Grid.Column="1"
                    Minimum="0"
                    Maximum="1"
                    Value="{Binding SeekPosition, Mode=TwoWay}"
                    VerticalAlignment="Center"
                    Margin="8,0"
                    IsHitTestVisible="{Binding IsNotPlaying}"
                    Thumb.DragStarted="SeekSlider_DragStarted"
                    Thumb.DragCompleted="SeekSlider_DragCompleted"/>

            <TextBlock Grid.Column="2"
                       Text="{Binding TotalDuration, StringFormat='{}{0:mm\\:ss\\.fff}'}"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="8,0"
                       FontFamily="Consolas"/>
        </Grid>
    </Grid>
</Window>
