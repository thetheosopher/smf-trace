<Window x:Class="SMFTrace.Wpf.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SMFTrace.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="About SMF Trace"
        Width="560"
        Height="560"
        MinWidth="560"
        MinHeight="560"
        Background="{DynamicResource DialogWindowBrush}"
        Icon="/SMFTrace;component/Resources/app-icon.ico"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        d:DataContext="{d:DesignInstance vm:AboutViewModel}">

    <Window.Resources>
        <SolidColorBrush x:Key="DialogWindowBrush" Color="#0B1020"/>
        <SolidColorBrush x:Key="DialogSurfaceBrush" Color="#F3F7FC"/>
        <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F172A" Offset="0"/>
            <GradientStop Color="#123E7A" Offset="0.6"/>
            <GradientStop Color="#1D78C8" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="HeroTitleBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="HeroSubtitleBrush" Color="#D8E8FF"/>
        <SolidColorBrush x:Key="HeroChipBrush" Color="#20FFFFFF"/>
        <SolidColorBrush x:Key="HeroChipTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="HeroIconPlateBrush" Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="HeroIconBorderBrush" Color="#66D5EBFF"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#243247"/>
        <SolidColorBrush x:Key="InfoCardBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="InfoCardBorderBrush" Color="#D5E1EF"/>
        <SolidColorBrush x:Key="SectionLabelBrush" Color="#4C5D78"/>
        <SolidColorBrush x:Key="InfoPrimaryBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CardButtonBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="CardButtonBorderBrush" Color="#D5E1EF"/>
        <SolidColorBrush x:Key="CardButtonHoverBackgroundBrush" Color="#F6FAFF"/>
        <SolidColorBrush x:Key="CardButtonHoverBorderBrush" Color="#7FB6FF"/>
        <SolidColorBrush x:Key="CardButtonPressedBackgroundBrush" Color="#EAF3FF"/>
        <SolidColorBrush x:Key="CardButtonPressedBorderBrush" Color="#4B8EE6"/>
        <SolidColorBrush x:Key="CardTitleBrush" Color="#111827"/>
        <SolidColorBrush x:Key="CardTextBrush" Color="#4B5D78"/>
        <SolidColorBrush x:Key="GitHubLinkBrush" Color="#1D78C8"/>
        <SolidColorBrush x:Key="SupportLinkBrush" Color="#B35A00"/>
        <SolidColorBrush x:Key="FooterBrush" Color="#E8EFF8"/>
        <SolidColorBrush x:Key="FooterTextBrush" Color="#617189"/>
        <SolidColorBrush x:Key="CloseButtonBrush" Color="#1D78C8"/>
        <SolidColorBrush x:Key="CloseButtonHoverBrush" Color="#1667AE"/>
        <SolidColorBrush x:Key="CloseButtonPressedBrush" Color="#11558F"/>
        <SolidColorBrush x:Key="CloseButtonForegroundBrush" Color="#FFFFFF"/>

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource CardButtonHoverBackgroundBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource CardButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardBorder" Property="Background" Value="{DynamicResource CardButtonPressedBackgroundBrush}"/>
                                <Setter TargetName="CardBorder" Property="BorderBrush" Value="{DynamicResource CardButtonPressedBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CloseButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource CloseButtonForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CloseButtonBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CloseButtonHoverBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource CloseButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource CloseButtonPressedBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource CloseButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource DialogWindowBrush}" Padding="1">
        <Border Background="{DynamicResource DialogSurfaceBrush}" CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource HeroBackgroundBrush}" Padding="24" CornerRadius="18,18,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="88" Height="88"
                                Padding="12"
                                CornerRadius="22"
                                Background="{DynamicResource HeroIconPlateBrush}"
                                BorderBrush="{DynamicResource HeroIconBorderBrush}"
                                BorderThickness="1">
                            <Image Source="/SMFTrace;component/Resources/app-icon.ico" Stretch="Uniform"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ApplicationName}"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource HeroTitleBrush}"/>
                            <TextBlock Text="{Binding Tagline}"
                                       Margin="0,6,0,0"
                                       FontSize="15"
                                       Foreground="{DynamicResource HeroSubtitleBrush}"/>
                            <TextBlock Text="{Binding CopyrightText}"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       Foreground="{DynamicResource HeroSubtitleBrush}"/>
                            <Border Margin="0,12,0,0"
                                    Padding="10,4"
                                    Background="{DynamicResource HeroChipBrush}"
                                    CornerRadius="999"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding VersionText}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource HeroChipTextBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="24,22,24,18">
                    <TextBlock Text="{Binding Description}"
                               Foreground="{DynamicResource BodyTextBrush}"
                               FontSize="14"
                               TextWrapping="Wrap"/>

                    <UniformGrid Rows="1" Columns="2" Margin="0,18,0,0">
                        <Button Style="{StaticResource CardButtonStyle}" Command="{Binding OpenGitHubCommand}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="GitHub Project"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource CardTitleBrush}"/>
                                <TextBlock Text="{Binding GitHubBlurb}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource CardTextBrush}"/>
                                <TextBlock Text="{Binding GitHubUrl}"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource GitHubLinkBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource CardButtonStyle}" Command="{Binding OpenBuyMeACoffeeCommand}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Buy Me A Coffee"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource CardTitleBrush}"/>
                                <TextBlock Text="{Binding BuyMeACoffeeBlurb}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource CardTextBrush}"/>
                                <TextBlock Text="{Binding BuyMeACoffeeUrl}"
                                           Margin="0,12,0,0"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SupportLinkBrush}"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>

                <Border Grid.Row="2" Background="{DynamicResource FooterBrush}" Padding="16,12" CornerRadius="0,0,18,18">
                    <StackPanel HorizontalAlignment="Right">
                        <Button Content="Close"
                                Width="100"
                                IsCancel="True"
                                Style="{StaticResource CloseButtonStyle}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
