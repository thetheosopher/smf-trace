{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build-solution",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"build",
				"c:\\Projects\\Applications\\SMF Trace\\SMFTrace.slnx"
			],
			"problemMatcher": [],
			"group": "build"
		},
		{
			"label": "test-solution",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"test",
				"c:\\Projects\\Applications\\SMF Trace\\SMFTrace.slnx",
				"--no-build"
			],
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "test"
		},
		{
			"label": "portable-build",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}\\build\\portable-build.ps1"
			],
			"problemMatcher": [],
			"group": "build"
		}
	]
}
